{{!
    @template block_townsquare/content

    This template renders the main content area for the townsquare block.

     Variables required for this template:
     * content - Array with content
     * lastupdate - Last update timestamp

    Example context (json):
    {
        "lastupdate": "Last updated: 14:30",
        "content": [
            {
                "day": "2026-03-31",
                "letters": [
                    {
                         "contentid": 0,
                         "isbasic": true,
                         "coursename": "Moodle Engineering",
                         "courseid": 3,
                         "instancename": "Lesson 1: Quantum Theory",
                         "content": "Lesson 1: Quantum Theory closes",
                         "created": "20.12.2023",
                         "linktocourse": "http://localhost/moodle/course/view.php?id=20",
                         "linktoactivity": "http://localhost/moodle/mod/lesson/view.php?id=314",
                         "basiclettercolor": "#0f6cbf"
                    }
                ]
            }
        ]
    }
}}

<div class="d-flex townsquare_header">
    {{lastupdate}}
    <span class="ms-auto" id="ts_reload_button" role="button" data-action="ts_reload">
        <i class="fa fa-refresh fa-lg" aria-hidden="true"></i>
    </span>
</div>
<div class="townsquare_letters">
    {{#content}}
        <div class="ts-lettergroup" id="ts-lettergroup-{{day}}">
            <div class="orientationmarker">
                <span class="orientationmarker_date">{{day}}</span>
                <span class="orientationmarker_line" aria-hidden="true"></span>
                <span class="orientationmarker-collapse" data-action="block_townsquare/collapse_group" data-groupid="{{day}}">
                    <i class="fa fa-chevron-down ms-3 me-2"></i>
                </span>
            </div>
            <div class="ts-letter-box" data-groupid="{{day}}">
                {{#letters}}
                    {{#isbasic}}
                        {{> block_townsquare/letter/basicletter}}
                    {{/isbasic}}
                    {{#isactivitycompletion}}
                        {{> block_townsquare/letter/activitycompletionletter}}
                    {{/isactivitycompletion}}
                    {{#ispost}}
                        {{> block_townsquare/letter/postletter}}
                    {{/ispost}}
                {{/letters}}
            </div>
        </div>
    {{/content}}
</div>